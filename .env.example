# Copy this file to .env and adjust as needed.

# Which Vinted marketplace to watch (any national TLD: .it / .fr / .de / .co.uk / ...).
VINTED_DOMAIN=www.vinted.it

# Proxy for the requests — REQUIRED. Running this against your own IP will get it
# blocked by Vinted; the tool refuses to start without a proxy set here.
# Format: http://user:pass@host:port  (or http://host:port without auth)
HTTP_PROXY=http://user:pass@host:port

# ============================================================================
# ⚠️  IMPORTANT — country / domain / proxy must all match (for ACCESS, not content)
# ============================================================================
# The proxy's country, the VINTED_DOMAIN TLD, and the language must line up, or
# Vinted's anti-bot rejects mismatched IP<->domain requests and stops answering:
#
#   * The proxy IP country MUST match the TLD:
#       Italian proxy   -> VINTED_DOMAIN=www.vinted.it
#       French proxy    -> VINTED_DOMAIN=www.vinted.fr
#       German proxy    -> VINTED_DOMAIN=www.vinted.de
#   * Avoid www.vinted.com: it works but often serves cached/stale data — use a
#     national TLD (.it/.fr/.de/...) for a live feed.
#   * If you change country, change BOTH the proxy AND VINTED_DOMAIN together.
#   * A ROTATING proxy must be locked to ONE country (a country filter matching
#     the TLD). If it rotates across countries, requests land on the wrong geo
#     and Vinted stops answering — pin the pool to the same country as the TLD.
#
# This matching only decides WHETHER Vinted serves you — it does NOT filter the
# results. Item IDs are a single GLOBAL sequence and the catalog is not
# partitioned by country: whichever national domain you pick, you watch the same
# WORLDWIDE frontier and see every new listing everywhere, not just that country's.
# (Confirmed through extensive testing.)
#
# The Accept-Language header is derived automatically from VINTED_DOMAIN
# (it.it -> it-IT, .fr -> fr-FR, ...), so you don't set it by hand — just make
# sure VINTED_DOMAIN is right and the request headers follow.
# ============================================================================

# --- Optional tuning (defaults are fine to start) ---------------------------
# The tool runs a self-replenishing pool of short-lived sessions to dodge anti-bot bans;
# the heartbeat (stderr) shows pool size, throughput, error mix and coverage. Read it:
#   - pool draining (e.g. pool 40/100) or lots of "no-session" → raise SESSIONS, or lower
#     CONCURRENCY to match, or raise MAX_USES so sessions retire less often.
#   - many 403/429 → too many requests per IP; LOWER MAX_USES.
#   - many "net" (timeouts) → proxy choking on concurrency; lower CONCURRENCY.
#   - "gave-up" climbing and you want fewer misses → raise MAX_AGE (costs more probes).
#
# SESSIONS=200          # target warm sessions in the pool (keep >= CONCURRENCY)
# CONCURRENCY=150       # max probes in flight at once (throughput ~= this / latency)
# CREATE_CONCURRENCY=40 # how many sessions to warm up at once
# MAX_USES_MIN=100      # retire a session after this many requests (min) — anti-ban
# MAX_USES_MAX=200      # …and this many (max); random per session so they don't die together
# PROBE_INTERVAL=1.0    # min seconds between re-probes of the same id (spares the proxy)
# MAX_AGE=90            # seconds to keep re-probing an id before giving up on it
# PROBE_TIMEOUT=2       # per-probe timeout, seconds (~3-6x the typical latency)
# LOOKAHEAD=250         # how far above the frontier to watch for about-to-be-born ids
# HEARTBEAT=5           # seconds between status lines on stderr
# GAVEUP_LOG=           # set to a filename to record abandoned ids (audit with check.py)
